# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Lemon Squeezy (payment variants)
VITE_LEMON_SQUEEZY_MONTHLY_ID=your-monthly-variant-id
VITE_LEMON_SQUEEZY_YEARLY_ID=your-yearly-variant-id
# B2B Pro tier (Phase 1.4) — leave blank until the variant is created in Lemon
VITE_LEMON_SQUEEZY_B2B_MONTHLY_ID=

# Donation link
VITE_DONATION_URL=https://your-donation-url

# IndexNow (server-side only, set via Vercel env)
INDEXNOW_SECRET=generate-a-strong-random-secret

# Sentry (error tracking, server-side DSN)
VITE_SENTRY_DSN=https://your-dsn@sentry.io/project-id

# REST API (server-side, Vercel env vars — used by /api/v1/*)
# These let the serverless functions look up api_keys via Supabase REST.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
