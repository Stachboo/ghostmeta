# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Lemon Squeezy (payment variants)
VITE_LEMON_SQUEEZY_MONTHLY_ID=your-monthly-variant-id
VITE_LEMON_SQUEEZY_YEARLY_ID=your-yearly-variant-id

# Donation link
VITE_DONATION_URL=https://your-donation-url

# IndexNow (server-side only, set via Vercel env)
INDEXNOW_SECRET=generate-a-strong-random-secret
